  "keyFeatures": [
    "Process Control (start, stop, restart, kill servers)",
    "Console Relay (view and interact with server console in Discord)",
    "Backup System (automated backup creation and management)",
    "File Explorer (manage server files through Discord)",
    "Plugin Support (extend functionality for active processes)",
    "Addon System (extend bot functionality without active processes)",
    "Predefined Commands (custom console commands)",
    "Advanced Error Reporting (automatic error detection and Discord notifications)",
    "Multiple Server Support (manage multiple servers simultaneously)",
    "Flask Integration (download files larger than 5MB)"
  ],
